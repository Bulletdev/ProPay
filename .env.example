# Database
DATABASE_URL=postgresql://propay_user:propay_pass@localhost:5432/propay_development

# Redis
REDIS_URL=redis://localhost:6379/1

# JWT (must match prostaff-api INTERNAL_JWT_SECRET)
INTERNAL_JWT_SECRET=your_internal_jwt_secret_here

# PIX Provider (openpix | efi)
PROPAY_PROVIDER=openpix

# OpenPix credentials
PROPAY_OPENPIX_APP_ID=your_openpix_app_id_here
PROPAY_OPENPIX_SECRET=your_openpix_webhook_secret_here

# ProStaff API integration
PROSTAFF_API_URL=http://localhost:3333/api/v1

# Iodine server
IODINE_THREADS=4
IODINE_WORKERS=1

# Debug
DB_LOGGING=false

# Rack::Attack
RACK_ATTACK_THROTTLE_LIMIT=100
RACK_ATTACK_THROTTLE_PERIOD=60
